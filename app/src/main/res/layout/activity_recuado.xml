<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    tools:context=".RecuadoActivity">

    <TextView
        android:id="@+id/text2_exibir_nome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="240dp"
        android:gravity="center"
        android:text="@string/desistencia_assim_tao_facil_voce_foi_elimidado"
        android:textColor="@color/vermelho"
        android:textSize="45sp" />

    <ImageButton
        android:id="@+id/button_voltar_image"
        android:layout_width="100dp"
        android:layout_height="140dp"
        android:src="@drawable/baseline_logout_24"
        android:background="@color/vermelho"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="410dp"
        android:contentDescription="@string/voltar_ao_menu"
        android:padding="10dp"
        android:scaleType="fitCenter" />
</RelativeLayout>